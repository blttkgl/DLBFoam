FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

chemistryType
{
    solver          ode_pyJac;
    method          loadBalanced_pyJac;
}

chemistry       on;

initialChemicalTimeStep 1e+30;

odeCoeffs
{
    solver          seulex_LAPACK;
    absTol          1e-12;
    relTol          1e-12;
}

loadbalancing
{
    log             false;
}

refmapping
{
}

#include        "../../../pyjacTestMechanism/foam/reactions.foam"
#includeEtc     "caseDicts/solvers/chemistry/TDAC/chemistryProperties.cfg"
tabulation
{
    method          ISAT_pyJac;
}

reduction
{
    method          none;
}


